    {
      "path": "styles/reka-vega/ui/pagination/Pagination.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationRootEmits, PaginationRootProps } from 'reka-ui'\nimport type { HTMLAttributes } from 'vue'\nimport { reactiveOmit } from '@vueuse/core'\nimport { PaginationRoot, useForwardPropsEmits } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\nconst props = defineProps<PaginationRootProps & {\n  class?: HTMLAttributes['class']\n}>()\nconst emits = defineEmits<PaginationRootEmits>()\n\nconst delegatedProps = reactiveOmit(props, 'class')\nconst forwarded = useForwardPropsEmits(delegatedProps, emits)\n</script>\n\n<template>\n  <PaginationRoot\n    v-slot=\"slotProps\"\n    data-slot=\"pagination\"\n    v-bind=\"forwarded\"\n    :class=\"cn('mx-auto flex w-full justify-center', props.class)\"\n  >\n    <slot v-bind=\"slotProps\" />\n  </PaginationRoot>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationContent.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationListProps } from 'reka-ui'\nimport type { HTMLAttributes } from 'vue'\nimport { reactiveOmit } from '@vueuse/core'\nimport { PaginationList } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\nconst props = defineProps<PaginationListProps & { class?: HTMLAttributes['class'] }>()\n\nconst delegatedProps = reactiveOmit(props, 'class')\n</script>\n\n<template>\n  <PaginationList\n    v-slot=\"slotProps\"\n    data-slot=\"pagination-content\"\n    v-bind=\"delegatedProps\"\n    :class=\"cn('gap-1 flex items-center', props.class)\"\n  >\n    <slot v-bind=\"slotProps\" />\n  </PaginationList>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationEllipsis.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationEllipsisProps } from 'reka-ui'\n\nimport type { HTMLAttributes } from 'vue'\nimport { reactiveOmit } from '@vueuse/core'\nimport { MoreHorizontalIcon } from 'lucide-vue-next'\nimport { PaginationEllipsis } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\nconst props = defineProps<PaginationEllipsisProps & { class?: HTMLAttributes['class'] }>()\n\nconst delegatedProps = reactiveOmit(props, 'class')\n</script>\n\n<template>\n  <PaginationEllipsis\n    data-slot=\"pagination-ellipsis\"\n    v-bind=\"delegatedProps\"\n    :class=\"cn('size-9 [&_svg:not([class*=\\'size-\\'])]:size-4 flex items-center justify-center', props.class)\"\n  >\n    <slot>\n      <MoreHorizontalIcon />\n      <span class=\"sr-only\">More pages</span>\n    </slot>\n  </PaginationEllipsis>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationFirst.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationFirstProps } from 'reka-ui'\n\nimport type { HTMLAttributes } from 'vue'\nimport type { ButtonVariants } from '@/styles/reka-vega/ui/button'\nimport { reactiveOmit } from '@vueuse/core'\nimport { ChevronsLeftIcon } from 'lucide-vue-next'\nimport { PaginationFirst, useForwardProps } from 'reka-ui'\nimport { cn } from '@/lib/utils'\nimport { buttonVariants } from '@/styles/reka-vega/ui/button'\n\nconst props = withDefaults(defineProps<PaginationFirstProps & {\n  size?: ButtonVariants['size']\n  class?: HTMLAttributes['class']\n}>(), {\n  size: 'default',\n})\n\nconst delegatedProps = reactiveOmit(props, 'class', 'size')\nconst forwarded = useForwardProps(delegatedProps)\n</script>\n\n<template>\n  <PaginationFirst\n    data-slot=\"pagination-first\"\n    :class=\"cn(buttonVariants({ variant: 'ghost', size }), '', props.class)\"\n    v-bind=\"forwarded\"\n  >\n    <slot>\n      <ChevronsLeftIcon data-icon=\"inline-start\" />\n      <span class=\"hidden sm:block\">First</span>\n    </slot>\n  </PaginationFirst>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationItem.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationListItemProps } from 'reka-ui'\nimport type { HTMLAttributes } from 'vue'\nimport type { ButtonVariants } from '@/styles/reka-vega/ui/button'\nimport { reactiveOmit } from '@vueuse/core'\nimport { PaginationListItem } from 'reka-ui'\nimport { cn } from '@/lib/utils'\nimport { buttonVariants } from '@/styles/reka-vega/ui/button'\n\nconst props = withDefaults(defineProps<PaginationListItemProps & {\n  size?: ButtonVariants['size']\n  class?: HTMLAttributes['class']\n  isActive?: boolean\n}>(), {\n  size: 'icon',\n})\n\nconst delegatedProps = reactiveOmit(props, 'class', 'size', 'isActive')\n</script>\n\n<template>\n  <PaginationListItem\n    data-slot=\"pagination-item\"\n    v-bind=\"delegatedProps\"\n    :class=\"cn(\n      buttonVariants({\n        variant: isActive ? 'outline' : 'ghost',\n        size,\n      }),\n      props.class)\"\n  >\n    <slot />\n  </PaginationListItem>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationLast.vue",
      "content": "<script setup lang=\"ts\">\nimport type { PaginationLastProps } from 'reka-ui'\n\nimport type { HTMLAttributes } from 'vue'\nimport type { ButtonVariants } from '@/styles/reka-vega/ui/button'\nimport { reactiveOmit } from '@vueuse/core'\nimport { ChevronsRightIcon } from 'lucide-vue-next'\nimport { PaginationLast, useForwardProps } from 'reka-ui'\nimport { cn } from '@/lib/utils'\nimport { buttonVariants } from '@/styles/reka-vega/ui/button'\n\nconst props = withDefaults(defineProps<PaginationLastProps & {\n  size?: ButtonVariants['size']\n  class?: HTMLAttributes['class']\n}>(), {\n  size: 'default',\n})\n\nconst delegatedProps = reactiveOmit(props, 'class', 'size')\nconst forwarded = useForwardProps(delegatedProps)\n</script>\n\n<template>\n  <PaginationLast\n    data-slot=\"pagination-last\"\n    :class=\"cn(buttonVariants({ variant: 'ghost', size }), '', props.class)\"\n    v-bind=\"forwarded\"\n  >\n    <slot>\n      <span class=\"hidden sm:block\">Last</span>\n      <ChevronsRightIcon data-icon=\"inline-end\" />\n    </slot>\n  </PaginationLast>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "styles/reka-vega/ui/pagination/PaginationLink.vue",
      "content": "<script setup lang=\"ts\">\nimport type { HTMLAttributes } from 'vue'\nimport type { ButtonVariants } from '@/styles/reka-vega/ui/button'\nimport { cn } from '@/lib/utils'\nimport { buttonVariants } from '@/styles/reka-vega/ui/button'\n\nconst props = withDefaults(defineProps<{\n  href?: string\n  size?: ButtonVariants['size']\n  isActive?: boolean\n  class?: HTMLAttributes['class']\n}>(), {\n  size: 'icon',\n  isActive: false,\n})\n</script>\n\n<template>\n  <a\n    :href=\"href\"\n    data-slot=\"pagination-link\"\n    :data-active=\"isActive ? '' : undefined\"\n    :aria-current=\"isActive ? 'page' : undefined\"\n    :class=\"cn(\n      buttonVariants({\n        variant: isActive ? 'outline' : 'ghost',\n        size,\n      }),\n      '',\n      props.class,\n    )\"\n  >\n    <slot />\n  </a>\n</template>\n",
      "type": "registry:ui"
    },
    {
