{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "otp-05",
  "type": "registry:block",
  "description": "A simple OTP form with social providers.",
  "registryDependencies": [
    "button",
    "field",
    "input-otp"
  ],
  "files": [
    {
      "path": "registry/new-york-v4/blocks/otp-05/page.vue",
      "content": "<script setup lang=\"ts\">\r\nimport OTPForm from \"@/registry/new-york-v4/blocks/otp-05/components/OTPForm.vue\"\r\n</script>\r\n\r\n<template>\r\n  <div class=\"bg-background flex min-h-svh flex-col items-center justify-center gap-6 p-6 md:p-10\">\r\n    <div class=\"w-full max-w-sm\">\r\n      <OTPForm />\r\n    </div>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:page",
      "target": "pages/otp/index.vue"
    },
    {
      "path": "registry/new-york-v4/blocks/otp-05/components/OTPForm.vue",
      "content": "<script setup lang=\"ts\">\r\nimport type { HTMLAttributes } from \"vue\"\r\n\r\nimport { GalleryVerticalEnd } from \"lucide-vue-next\"\r\nimport { cn } from \"@/registry/new-york-v4/lib/utils\"\r\nimport { Button } from \"@/registry/new-york-v4/ui/button\"\r\nimport {\r\n  Field,\r\n  FieldDescription,\r\n  FieldGroup,\r\n  FieldLabel,\r\n} from \"@/registry/new-york-v4/ui/field\"\r\nimport {\r\n  InputOTP,\r\n  InputOTPGroup,\r\n  InputOTPSeparator,\r\n  InputOTPSlot,\r\n} from \"@/registry/new-york-v4/ui/input-otp\"\r\n\r\nconst props = defineProps<{\r\n  class?: HTMLAttributes[\"class\"]\r\n}>()\r\n</script>\r\n\r\n<template>\r\n  <div :class=\"cn('flex flex-col gap-6', props.class)\">\r\n    <form>\r\n      <FieldGroup>\r\n        <div class=\"flex flex-col items-center gap-2 text-center\">\r\n          <a\r\n            href=\"#\"\r\n            class=\"flex flex-col items-center gap-2 font-medium\"\r\n          >\r\n            <div class=\"flex size-8 items-center justify-center rounded-md\">\r\n              <GalleryVerticalEnd class=\"size-6\" />\r\n            </div>\r\n            <span class=\"sr-only\">Acme Inc.</span>\r\n          </a>\r\n          <h1 class=\"text-xl font-bold\">\r\n            Enter verification code\r\n          </h1>\r\n          <FieldDescription>\r\n            We sent a 6-digit code to your email address\r\n          </FieldDescription>\r\n        </div>\r\n        <Field>\r\n          <FieldLabel for=\"otp\" class=\"sr-only\">\r\n            Verification code\r\n          </FieldLabel>\r\n          <InputOTP\r\n            id=\"otp\"\r\n            :maxlength=\"6\"\r\n            required\r\n            container-class=\"gap-4\"\r\n          >\r\n            <InputOTPGroup class=\"gap-2.5 *:data-[slot=input-otp-slot]:h-16 *:data-[slot=input-otp-slot]:w-12 *:data-[slot=input-otp-slot]:rounded-md *:data-[slot=input-otp-slot]:border *:data-[slot=input-otp-slot]:text-xl\">\r\n              <InputOTPSlot :index=\"0\" />\r\n              <InputOTPSlot :index=\"1\" />\r\n              <InputOTPSlot :index=\"2\" />\r\n            </InputOTPGroup>\r\n            <InputOTPSeparator />\r\n            <InputOTPGroup class=\"gap-2.5 *:data-[slot=input-otp-slot]:h-16 *:data-[slot=input-otp-slot]:w-12 *:data-[slot=input-otp-slot]:rounded-md *:data-[slot=input-otp-slot]:border *:data-[slot=input-otp-slot]:text-xl\">\r\n              <InputOTPSlot :index=\"3\" />\r\n              <InputOTPSlot :index=\"4\" />\r\n              <InputOTPSlot :index=\"5\" />\r\n            </InputOTPGroup>\r\n          </InputOTP>\r\n          <FieldDescription class=\"text-center\">\r\n            Didn't receive the code? <a href=\"#\">Resend</a>\r\n          </FieldDescription>\r\n        </Field>\r\n        <Field>\r\n          <Button type=\"submit\">\r\n            Verify\r\n          </Button>\r\n        </Field>\r\n      </FieldGroup>\r\n    </form>\r\n    <FieldDescription class=\"px-6 text-center\">\r\n      By clicking continue, you agree to our <a href=\"#\">Terms of Service</a>\r\n      and <a href=\"#\">Privacy Policy</a>.\r\n    </FieldDescription>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component"
    }
  ],
  "categories": [
    "authentication",
    "otp"
  ]
}
