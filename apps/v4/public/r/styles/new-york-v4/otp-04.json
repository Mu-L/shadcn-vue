      "path": "registry/new-york-v4/blocks/otp-04/page.vue",
      "content": "<script setup lang=\"ts\">\r\nimport OTPForm from \"@/registry/new-york-v4/blocks/otp-04/components/OTPForm.vue\"\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex min-h-svh w-full items-center justify-center p-6 md:p-10\">\r\n    <div class=\"w-full max-w-sm md:max-w-3xl\">\r\n      <OTPForm />\r\n    </div>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:page",
      "target": "pages/otp/index.vue"
    },
    {
      "path": "registry/new-york-v4/blocks/otp-04/components/OTPForm.vue",
      "content": "<script setup lang=\"ts\">\r\nimport type { HTMLAttributes } from \"vue\"\r\nimport { cn } from \"@/registry/new-york-v4/lib/utils\"\r\nimport { Button } from \"@/registry/new-york-v4/ui/button\"\r\nimport { Card, CardContent } from \"@/registry/new-york-v4/ui/card\"\r\nimport {\r\n  Field,\r\n  FieldDescription,\r\n  FieldGroup,\r\n  FieldLabel,\r\n} from \"@/registry/new-york-v4/ui/field\"\r\nimport {\r\n  InputOTP,\r\n  InputOTPGroup,\r\n  InputOTPSeparator,\r\n  InputOTPSlot,\r\n} from \"@/registry/new-york-v4/ui/input-otp\"\r\n\r\nconst props = defineProps<{\r\n  class?: HTMLAttributes[\"class\"]\r\n}>()\r\n</script>\r\n\r\n<template>\r\n  <div :class=\"cn('flex flex-col gap-6 md:min-h-[450px]', props.class)\">\r\n    <Card class=\"flex-1 overflow-hidden p-0\">\r\n      <CardContent class=\"grid flex-1 p-0 md:grid-cols-2\">\r\n        <form class=\"flex flex-col items-center justify-center p-6 md:p-8\">\r\n          <FieldGroup>\r\n            <Field class=\"items-center text-center\">\r\n              <h1 class=\"text-2xl font-bold\">\r\n                Enter verification code\r\n              </h1>\r\n              <p class=\"text-muted-foreground text-sm text-balance\">\r\n                We sent a 6-digit code to your email\r\n              </p>\r\n            </Field>\r\n            <Field>\r\n              <FieldLabel for=\"otp\" class=\"sr-only\">\r\n                Verification code\r\n              </FieldLabel>\r\n              <InputOTP\r\n                id=\"otp\"\r\n                :maxlength=\"6\"\r\n                required\r\n                container-class=\"gap-4\"\r\n              >\r\n                <InputOTPGroup>\r\n                  <InputOTPSlot :index=\"0\" />\r\n                  <InputOTPSlot :index=\"1\" />\r\n                  <InputOTPSlot :index=\"2\" />\r\n                </InputOTPGroup>\r\n                <InputOTPSeparator />\r\n                <InputOTPGroup>\r\n                  <InputOTPSlot :index=\"3\" />\r\n                  <InputOTPSlot :index=\"4\" />\r\n                  <InputOTPSlot :index=\"5\" />\r\n                </InputOTPGroup>\r\n              </InputOTP>\r\n              <FieldDescription class=\"text-center\">\r\n                Enter the 6-digit code sent to your email.\r\n              </FieldDescription>\r\n            </Field>\r\n            <Field>\r\n              <Button type=\"submit\">\r\n                Verify\r\n              </Button>\r\n              <FieldDescription class=\"text-center\">\r\n                Didn't receive the code? <a href=\"#\">Resend</a>\r\n              </FieldDescription>\r\n            </Field>\r\n          </FieldGroup>\r\n        </form>\r\n        <div class=\"bg-muted relative hidden md:block\">\r\n          <img\r\n            src=\"/placeholder.svg\"\r\n            alt=\"Image\"\r\n            class=\"absolute inset-0 h-full w-full object-cover dark:brightness-[0.2] dark:grayscale\"\r\n          >\r\n        </div>\r\n      </CardContent>\r\n    </Card>\r\n    <FieldDescription class=\"text-center\">\r\n      By clicking continue, you agree to our <a href=\"#\">Terms of Service</a>\r\n      and <a href=\"#\">Privacy Policy</a>.\r\n    </FieldDescription>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component"
    }
  ],
  "categories": [
    "authentication",
    "otp"
  ]
}
