  "files": [
    {
      "path": "registry/new-york-v4/blocks/otp-03/page.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { GalleryVerticalEnd } from \"lucide-vue-next\"\r\n\r\nimport OTPForm from \"@/registry/new-york-v4/blocks/otp-03/components/OTPForm.vue\"\r\n</script>\r\n\r\n<template>\r\n  <div class=\"bg-muted flex min-h-svh flex-col items-center justify-center gap-6 p-6 md:p-10\">\r\n    <div class=\"flex w-full max-w-xs flex-col gap-6\">\r\n      <a href=\"#\" class=\"flex items-center gap-2 self-center font-medium\">\r\n        <div class=\"bg-primary text-primary-foreground flex size-6 items-center justify-center rounded-md\">\r\n          <GalleryVerticalEnd class=\"size-4\" />\r\n        </div>\r\n        Acme Inc.\r\n      </a>\r\n      <OTPForm />\r\n    </div>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:page",
      "target": "pages/otp/index.vue"
    },
    {
      "path": "registry/new-york-v4/blocks/otp-03/components/OTPForm.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { Button } from \"@/registry/new-york-v4/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/registry/new-york-v4/ui/card\"\r\nimport {\r\n  Field,\r\n  FieldDescription,\r\n  FieldGroup,\r\n  FieldLabel,\r\n} from \"@/registry/new-york-v4/ui/field\"\r\nimport {\r\n  InputOTP,\r\n  InputOTPGroup,\r\n  InputOTPSlot,\r\n} from \"@/registry/new-york-v4/ui/input-otp\"\r\n</script>\r\n\r\n<template>\r\n  <Card>\r\n    <CardHeader class=\"text-center\">\r\n      <CardTitle class=\"text-xl\">\r\n        Enter verification code\r\n      </CardTitle>\r\n      <CardDescription>We sent a 6-digit code to your email.</CardDescription>\r\n    </CardHeader>\r\n    <CardContent>\r\n      <form>\r\n        <FieldGroup>\r\n          <Field>\r\n            <FieldLabel for=\"otp\" class=\"sr-only\">\r\n              Verification code\r\n            </FieldLabel>\r\n            <InputOTP id=\"otp\" :maxlength=\"6\" required>\r\n              <InputOTPGroup class=\"gap-2.5 *:data-[slot=input-otp-slot]:rounded-md *:data-[slot=input-otp-slot]:border\">\r\n                <InputOTPSlot :index=\"0\" />\r\n                <InputOTPSlot :index=\"1\" />\r\n                <InputOTPSlot :index=\"2\" />\r\n                <InputOTPSlot :index=\"3\" />\r\n                <InputOTPSlot :index=\"4\" />\r\n                <InputOTPSlot :index=\"5\" />\r\n              </InputOTPGroup>\r\n            </InputOTP>\r\n            <FieldDescription class=\"text-center\">\r\n              Enter the 6-digit code sent to your email.\r\n            </FieldDescription>\r\n          </Field>\r\n          <Button type=\"submit\">\r\n            Verify\r\n          </Button>\r\n          <FieldDescription class=\"text-center\">\r\n            Didn't receive the code? <a href=\"#\">Resend</a>\r\n          </FieldDescription>\r\n        </FieldGroup>\r\n      </form>\r\n    </CardContent>\r\n  </Card>\r\n</template>\r\n",
      "type": "registry:component"
    }
  ],
  "categories": [
    "authentication",
    "otp"
  ]
}
