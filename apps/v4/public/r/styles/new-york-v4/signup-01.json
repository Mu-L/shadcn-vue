{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "signup-01",
  "type": "registry:block",
  "description": "A simple signup form.",
  "registryDependencies": [
    "button",
    "card",
    "field",
    "input"
  ],
  "files": [
    {
      "path": "registry/new-york-v4/blocks/signup-01/page.vue",
      "content": "<script setup lang=\"ts\">\r\nimport SignupForm from \"@/registry/new-york-v4/blocks/signup-01/components/SignupForm.vue\"\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex min-h-svh w-full items-center justify-center p-6 md:p-10\">\r\n    <div class=\"w-full max-w-sm\">\r\n      <SignupForm />\r\n    </div>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:page",
      "target": "pages/signup/index.vue"
    },
    {
      "path": "registry/new-york-v4/blocks/signup-01/components/SignupForm.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { Button } from \"@/registry/new-york-v4/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/registry/new-york-v4/ui/card\"\r\nimport {\r\n  Field,\r\n  FieldDescription,\r\n  FieldGroup,\r\n  FieldLabel,\r\n} from \"@/registry/new-york-v4/ui/field\"\r\nimport { Input } from \"@/registry/new-york-v4/ui/input\"\r\n</script>\r\n\r\n<template>\r\n  <Card>\r\n    <CardHeader>\r\n      <CardTitle>Create an account</CardTitle>\r\n      <CardDescription>\r\n        Enter your information below to create your account\r\n      </CardDescription>\r\n    </CardHeader>\r\n    <CardContent>\r\n      <form>\r\n        <FieldGroup>\r\n          <Field>\r\n            <FieldLabel for=\"name\">\r\n              Full Name\r\n            </FieldLabel>\r\n            <Input id=\"name\" type=\"text\" placeholder=\"John Doe\" required />\r\n          </Field>\r\n          <Field>\r\n            <FieldLabel for=\"email\">\r\n              Email\r\n            </FieldLabel>\r\n            <Input\r\n              id=\"email\"\r\n              type=\"email\"\r\n              placeholder=\"m@example.com\"\r\n              required\r\n            />\r\n            <FieldDescription>\r\n              We'll use this to contact you. We will not share your email with\r\n              anyone else.\r\n            </FieldDescription>\r\n          </Field>\r\n          <Field>\r\n            <FieldLabel for=\"password\">\r\n              Password\r\n            </FieldLabel>\r\n            <Input id=\"password\" type=\"password\" required />\r\n            <FieldDescription>Must be at least 8 characters long.</FieldDescription>\r\n          </Field>\r\n          <Field>\r\n            <FieldLabel for=\"confirm-password\">\r\n              Confirm Password\r\n            </FieldLabel>\r\n            <Input id=\"confirm-password\" type=\"password\" required />\r\n            <FieldDescription>Please confirm your password.</FieldDescription>\r\n          </Field>\r\n          <FieldGroup>\r\n            <Field>\r\n              <Button type=\"submit\">\r\n                Create Account\r\n              </Button>\r\n              <Button variant=\"outline\" type=\"button\">\r\n                Sign up with Google\r\n              </Button>\r\n              <FieldDescription class=\"px-6 text-center\">\r\n                Already have an account? <a href=\"#\">Sign in</a>\r\n              </FieldDescription>\r\n            </Field>\r\n          </FieldGroup>\r\n        </FieldGroup>\r\n      </form>\r\n    </CardContent>\r\n  </Card>\r\n</template>\r\n",
      "type": "registry:component"
    }
  ],
  "categories": [
    "authentication",
    "signup"
  ]
}
